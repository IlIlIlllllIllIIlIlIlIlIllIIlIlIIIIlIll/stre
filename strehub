    Default = false,
    Callback = function(arg)
        if arg then
            local ball = workspace:FindFirstChild("TPSSystem") and workspace.TPSSystem:FindFirstChild("TPS")
            if ball then
                TouchedGKBallBox = ball.Touched:Connect(function(hit)
                    local char = game.Players.LocalPlayer.Character
                    if hit == char:FindFirstChild("HumanoidRootPart") then
                        local hum = char:FindFirstChildOfClass("Humanoid")
                        local animId = (hum.RigType == Enum.HumanoidRigType.R6) and "304581045" or "3008336125"
                        
                        local anim = Instance.new("Animation")
                        anim.AnimationId = "rbxassetid://" .. animId
                        local loadAnim = hum:LoadAnimation(anim)
                        loadAnim:Play()
                        
                        task.wait(SaveDelay)

                        if hum.RigType == Enum.HumanoidRigType.R6 then
                            workspace.FE.Actions.SaveRL:FireServer(ball, char["Right Leg"])
                        else
                            workspace.FE.Actions.SaveT:FireServer(ball, char.HumanoidRootPart)
                        end
                        workspace.FE.Kick.RemoteEvent2:FireServer()
                    end
                end)
            end
        else
            if TouchedGKBallBox then TouchedGKBallBox:Disconnect() TouchedGKBallBox = nil end
        end
    end
})

