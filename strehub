-- [[ GÖRSEL KUTU OLUŞTURUCU ]] --
local function GetOrCreateIndicator(name)
    if Indicators[name] then return Indicators[name] end
    local p = Instance.new("Part")
    p.Name = name .. "Indicator"
    p.Shape = Enum.PartType.Block
    p.Material = Enum.Material.Neon
    p.Color = IndicatorConfig[name].Color
    p.Transparency = 1
    p.Anchored = true
    p.CanCollide = false
    p.CanTouch = false -- Dokunmayı bozmaması için kapalı
    p.Parent = workspace
    Indicators[name] = p
    return p
end

-- [[ ANA DÖNGÜ ]] --
RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    if not char or not TPS_BALL_PATH then return end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local ballPos = TPS_BALL_PATH.Position
    local hrpPos = hrp.Position

    for groupName, distance in pairs(_G.ReachSettings) do
        -- Indicator Güncelleme
        local visual = GetOrCreateIndicator(groupName)
        if distance > 0 and IndicatorConfig[groupName].Enabled then
            visual.Transparency = 0.8
            visual.CFrame = hrp.CFrame
            visual.Size = Vector3.new(distance * 2, distance * 2, distance * 2)
        else
            visual.Transparency = 1
        end

        -- Reach Kontrolü
        if distance > 0 and (hrpPos - ballPos).Magnitude <= distance then
            local parts = BodyGroups[groupName]
            for i = 1, #parts do
                local p = char:FindFirstChild(parts[i])
                if p then
                    firetouchinterest(p, TPS_BALL_PATH, 0)
                    task.wait() 
                    firetouchinterest(p, TPS_BALL_PATH, 1)
                end
            end
        end
    end
end)

